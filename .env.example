# .env.example — Copy to .env.local and fill in values

# Required — App will not start without these
PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...
ANTHROPIC_API_KEY=sk-ant-...

# Optional — Features disabled when absent
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_RUNAME=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
PUBLIC_GOOGLE_CLIENT_ID=

# Hugging Face Inference API token (Session 1.6 embedding Tier 1).
# Read-only token; generate at https://huggingface.co/settings/tokens.
# Required by /api/scan/embedding and by scripts/seed-card-embeddings.ts.
# Seeding additionally needs SUPABASE_SERVICE_ROLE_KEY.
HF_INFERENCE_TOKEN=
SUPABASE_SERVICE_ROLE_KEY=

# OAuth state secret — signs the `state` parameter passed through eBay's
# OAuth flow so the callback can deep-link the user back to the page they
# initiated Connect from. Generate via `openssl rand -hex 32`. Optional:
# when unset, the eBay callback falls back to /settings as before.
OAUTH_STATE_SECRET=
