# .env.example — BOBA Scanner Environment Variables

# Supabase (required) — public keys, safe for client-side
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic Claude API (required for Tier 3 AI scanning)
CLAUDE_API_KEY=sk-ant-...
# ANTHROPIC_API_KEY=sk-ant-...  # Alternative name

# eBay Browse API (required for price lookups)
EBAY_CLIENT_ID=your-ebay-client-id
EBAY_CLIENT_SECRET=your-ebay-client-secret

# Upstash Redis (optional — enables shared hash cache + rate limiting)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
